<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net10.0-windows;net9.0-windows;net8.0-windows;net471;net462</TargetFrameworks>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <ImplicitUsings>disable</ImplicitUsings>
    <Description>NuExt.Presentation.Wpf provides WPF-focused presentation helpers for the NuExt ecosystem: XAML resources and styles, control and framework extensions, binding/data helpers, diagnostics, and templating utilities.

Commonly used types:
Presentation.Wpf.WindowPlacement
Presentation.Wpf.Data.BindingProxy
Presentation.Wpf.Data.BindingProxy`1
Presentation.Wpf.Controls.ComboBoxExtensions
Presentation.Wpf.Controls.ControlExtensions
Presentation.Wpf.Controls.TreeViewItemHelper
Presentation.Wpf.Controls.VirtualizingStackPanelExtensions
Presentation.Wpf.Templating.ComboBoxItemTemplateSelector
Presentation.Wpf.Diagnostics.BindingErrorTraceListener
Presentation.Wpf.FrameworkElementExtensions
Presentation.Wpf.DependencyObjectExtensions
Presentation.Wpf.WindowExtensions</Description>
    <RootNamespace>Presentation.Wpf</RootNamespace>
    <GenerateDocumentationFile>True</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591;NETSDK1233</NoWarn>
    <VersionPrefix>0.7.5</VersionPrefix>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Windows.CsWin32" Version="0.3.298">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup Condition="'$(NuExt_UseLocalProjects)' != 'true'">
    <PackageReference Include="NuExt.System" Version="0.7.5" />
  </ItemGroup>

  <ItemGroup Condition="'$(NuExt_UseLocalProjects)' == 'true'">
    <ProjectReference Include="..\..\NuExt.System\src\NuExt.System.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="$(MSBuildProjectName).Tests" Key="" />
  </ItemGroup>

</Project>
